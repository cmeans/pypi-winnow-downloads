# Example Caddyfile for serving pypi-winnow-downloads badge JSON over HTTPS.
#
# Caddy auto-provisions a Let's Encrypt certificate for the host name
# below via ACME HTTP-01 the first time it's reached on port 80. Make
# sure ports 80 and 443 are reachable from the public internet (router
# port-forward, firewall, etc.) before starting Caddy on this domain
# or ACME will fail.
#
# Install steps (Debian-family, Caddy installed from caddyserver.com):
#   sudo cp Caddyfile.example /etc/caddy/Caddyfile
#   # Set the BADGE_HOST env var or replace {$BADGE_HOST:badges.example.com}
#   # below with your actual public hostname.
#   sudo systemctl reload caddy
#
# Verify after first hit:
#   curl -sI https://<your-host>/<some-package>/downloads-30d-non-ci.json
# A 200 with Content-Type: application/json means you're good.
#
# Logging (see "global options" + per-site "log" blocks below):
#   /var/log/caddy/error.log    server-level errors (ACME, config, panic)
#   /var/log/caddy/access.log   per-request entries in JSON
# Both files use Caddy's built-in lumberjack rotation (size + count + age),
# so no separate logrotate config is required. The Caddy package's
# postinst creates /var/log/caddy/ owned by caddy:caddy, which is what
# the daemon needs to open these files for writing.
#
# Gotcha: never run `caddy validate` against this file as root before
# the daemon has had a chance to create the log files itself. Doing so
# pre-creates /var/log/caddy/{error,access}.log as root:root with mode
# 0600, which the caddy daemon (running as user `caddy`) then can't
# open — reload fails with "permission denied" and the unit gets stuck
# in `reloading`. If this happens: chown caddy:caddy on the log files
# and `systemctl restart caddy` to recover.

# --- global options -----------------------------------------------------
#
# Server-level (non-request) errors land in /var/log/caddy/error.log
# with built-in size + count + age rotation. Without this, errors go
# to stdout and only journalctl -u caddy captures them, which is hard
# to grep across a long window. Keep these longer than access logs
# because they're rare and forensically valuable.
{
	log default {
		output file /var/log/caddy/error.log {
			roll_size 50MiB
			roll_keep 10
			roll_keep_for 2160h  # 90 days
		}
		level ERROR
		format json
	}
}

{$BADGE_HOST:badges.example.com} {
	# Static file serving from the collector's output directory. Caddy
	# (in production) typically runs as the `caddy` system user — make
	# sure that user can read /var/lib/pypi-winnow-downloads/output/.
	root * /var/lib/pypi-winnow-downloads/output
	file_server {
		# Don't expose a directory listing — the package list is implied
		# by config.yaml and not something we want public.
		index off
	}

	# Set Content-Type and CORS for the JSON badge files. shields.io
	# fetches server-side so CORS isn't strictly required for shields.io
	# itself, but allows direct browser consumption of the JSON.
	@badge_json {
		path *.json
	}
	header @badge_json Content-Type "application/json"
	header @badge_json Access-Control-Allow-Origin "*"
	# shields.io's badge CDN caches endpoint responses for hours regardless
	# of upstream Cache-Control. This header makes our own cache stance
	# explicit and is a hint to other consumers; the daily collector run
	# tolerates it well.
	header @badge_json Cache-Control "public, max-age=3600"

	encode zstd gzip

	# Per-site access log (request/response). JSON format is parseable
	# by jq, fluentd, vector, etc. Caddy's built-in lumberjack rotation
	# keeps disk usage bounded without needing logrotate.
	#   roll_size       100MiB  — rotate when file hits this size
	#   roll_keep       14      — keep at most 14 rotated files (~1.4 GB ceiling)
	#   roll_keep_for   720h    — 30 days; older rotations are deleted
	# Low-traffic badge service: a single 100 MiB log file may last
	# weeks, so retention is effectively bounded by roll_keep_for.
	log {
		output file /var/log/caddy/access.log {
			roll_size 100MiB
			roll_keep 14
			roll_keep_for 720h  # 30 days
		}
		format json
	}
}
